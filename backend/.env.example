# Nüvo Backend Configuration Example
# Copy this file to .env and fill in your credentials

PORT=5000

# SMTP Server Configurations
# For Gmail, use host: smtp.gmail.com, port: 465, secure: true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true

# SMTP Authentication Credentials
# SMTP_USER should be your Gmail: aritrakundu.in@gmail.com
# SMTP_PASS should be your Gmail App Password (NOT your account password)
# Learn how to create one: https://support.google.com/accounts/answer/185833
SMTP_USER=aritrakundu.in@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Recipient Email Address
# Where you want the consultation leads to be sent
RECEIVER_EMAIL=aritrakundu.in@gmail.com
